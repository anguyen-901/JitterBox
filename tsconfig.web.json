{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": ["src", "src/types"],
  "compilerOptions": {
    "composite": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["src/*"],
      "@/*": ["src/*"]
    }
  }
}
